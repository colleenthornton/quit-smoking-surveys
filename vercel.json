{
  "rewrites": [
    { "source": "/current-smokers", "destination": "/current-smokers.html" },
    { "source": "/ex-smokers", "destination": "/ex-smokers.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
