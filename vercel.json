{
  "rewrites": [
    { "source": "/current-smokers", "destination": "/current-smokers.html" },
    { "source": "/ex-smokers", "destination": "/ex-smokers.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Project", "value": "smokesignal" }
      ]
    }
  ]
}
